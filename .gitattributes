# Auto detect text files and normalize line endings to LF
* text=auto

# Source code
*.java text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.properties text eol=lf
*.sql text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf
/mvnw text eol=lf

# Windows batch files
*.cmd text eol=crlf
*.bat text eol=crlf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf

# Docker
Dockerfile text eol=lf
docker-compose.yml text eol=lf

# Binary files
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
